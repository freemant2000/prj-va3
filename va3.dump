INSERT INTO `sentences` VALUES (4882,'10減1等於9。'),(15032,'2020年之前中國的漁夫已知道了那個日期。'),(6566,'2020年之前他已經探訪了一間現代的郵局。'),(6604,'2020年之前他已經油了那道門。'),(15420,'2020年之前他已經買了這張椅子。'),(15077,'2020年之前那個洞已存在。'),(9693,'2020年之前那個為人設想的小販已開始了使這本習題簿。'),(9613,'2020年以來他就沒有使用便宜的膠擦。'),(9343,'2020年以來他都沒有看見到一塊溫暖的石頭。'),(9366,'2020年以來他都沒有買花。'),(14580,'2020年以前那個年輕的農夫已經數了那些鉛筆。'),(6325,'8除以2等於4。'),(1447,'9的一個平方根是3。'),(1427,'AD是這個等邊三角形的一條角平分線。'),(1539,'AI年代會很快來臨(不用come)。'),(178,'Amy和Paul是好的學生。'),(172,'Amy和我是學生。'),(1673,'Android的用戶數目很多年前超越了iPhone。'),(10946,'A和B兩者之一是一件令人愉快的藝術品。'),(10904,'A和B其中之一是假的。'),(12647,'A和B其中之一是滿的。'),(8561,'A和B其中之一會發生。'),(1425,'A是這個平行四邊形的一條邊的中點。'),(1207,'A減B等於2。'),(10837,'Covid擴散得更遠了。'),(614,'Good的一個反義詞是bad。'),(13300,'John或Paul明白我的沮喪。'),(6347,'John正在洗黑板。'),(3603,'John責備Paul，但我相信後者。'),(18599,'PH計比通用指示劑有更高的精確度。'),(613,'Sick的一個同義詞是ill。'),(17457,'「他」指的是那個在那個籠裡的感到悶的外國人。'),(15966,'「他」指的是那個好極的天才。'),(8720,'「他」指的是那個經理。'),(9152,'「他」指的是那锢正在放鬆的人。'),(9675,'「他們」指的是那幾個可靠的人。'),(5785,'「冷靜的」有幾個反義詞。'),(998,'「夫人」指的是一個領主的妻子。'),(14724,'「它」很可能指埃及的邊緣。'),(14786,'「它」很可能指的是他的胃。'),(15916,'「它」指的是你待它很好的那架車。'),(15882,'「它」指的是在那個遠離的地方的那個色士風。'),(9558,'「它」指的是我們的生計。'),(14686,'「它」指的是這張枱的邊緣。'),(16700,'「它」指的是那個一生人一次的機會。'),(16593,'「它」指的是那個一生人一次的體驗。'),(17521,'「它」指的是那個外國人的決心。'),(16658,'「它」指的是那個方向。'),(14002,'「它」指的是那個頭條。'),(15840,'「它」指的是那張枱的底部。'),(5667,'「它」指的是那間國際學校。'),(14638,'「它」指的是那間屋的底部。'),(8267,'「它」指的是鐵器時代。'),(8334,'「它」指稱的是那個搶刧。'),(15947,'「它們」指的是他的屋和我的。'),(11985,'「整正容手術不是無目的的」，它的支持者說。'),(5718,'「極骯髒的」反義詞是「清潔的」。'),(7397,'「牠」指的是那個有毒的物種。'),(860,'「生命」的反義詞是「死亡」。'),(913,'「相似的」的反義詞是甚麼？'),(17455,'一些一般的洗手間出現了。'),(11408,'一些創新出現了。'),(1999,'一些印度人犯了法。'),(16275,'一些厚的草在這個屋頂（結構）上。'),(14704,'一些友好的動物在發售。'),(11059,'一些嚇人的食物正在發售。'),(7304,'一些基金經理恐慌了。'),(17494,'一些家居的清潔用品是有酸味的。'),(14760,'一些市民破壞了那個鐵欄。'),(17761,'一些微生物會製造乳酸。'),(1682,'一些成年人也克服不自己恐惧(fear)。'),(6987,'一些支持者已到達了那間屋。'),(10495,'一些政治的慈善機構已經出現了。'),(962,'一些教育工作者在捱餓中爭扎。'),(4297,'一些新的公寓大樓出現了。'),(9762,'一些新的士多已經出現了。'),(17507,'一些新的色士風出現了。'),(16383,'一些時髦的商店出現了。'),(12262,'一些時髦的收音機在這間劇院裡是可提供的。'),(157